# Copy this file to .env and fill in your real project values.
# All EXPO_PUBLIC_* vars are bundled into the client - never put a service-role
# key or secret here, only public/anon keys.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat public SDK keys (from RevenueCat project settings -> API keys)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxx
